# Authentication Credentials
INNTOUCH_USERNAME=your_username_here
INNTOUCH_PASSWORD=your_password_here

# Crawler Configuration
BASE_URL=https://www.inn-touch.ca
LIBRARY_URL=https://www.inn-touch.ca/community/local-sales-library?forceNoRedirect=true
HEADLESS=true
DOWNLOAD_FILES=true

# Output Configuration
OUTPUT_DIR=./output
DOWNLOAD_DIR=./downloads

# Crawl Limits
MAX_DEPTH=3
MAX_PAGES=100
CRAWL_DELAY=1000

# Logging
LOG_LEVEL=info
