{
  "name": "Hotel Design and Vendors - Legacy Renovation + Blog Posts (page-scoped)",
  "startUrl": [
    "https://www.inn-touch.ca/community/legacy-comfort-renovation/pages/legacy-comfort-renovation",
    "https://www.inn-touch.ca/community/hotel-design-and-vendors/blog/2026/04/10/d%C3%A9couvrez-notre-nouveau-fournisseur-qualifi%C3%A9",
    "https://www.inn-touch.ca/community/hotel-design-and-vendors/blog/2026/02/24/meet-our-newest-qualified-vendors",
    "https://www.inn-touch.ca/community/hotel-design-and-vendors/blog/2025/10/28/meet-our-newest-qualified-vendor"
  ],
  "headless": true,
  "auth": {
    "strategy": "form",
    "loginUrl": "https://www.inn-touch.ca/login.jspa",
    "credentials": {
      "username": "${INNTOUCH_USERNAME}",
      "password": "${INNTOUCH_PASSWORD}"
    },
    "selectors": {
      "username": "input[name='username'], input#username",
      "password": "input[name='password'], input#password",
      "submit": "button[type='submit'], input[type='submit']"
    },
    "successIndicator": {
      "urlNotContains": "/login"
    }
  },
  "crawl": {
    "maxDepth": 1,
    "maxPages": 30,
    "allowedDomains": ["www.inn-touch.ca", "inn-touch.ca"],
    "includePatterns": [
      "/community/legacy-comfort-renovation",
      "/community/hotel-design-and-vendors",
      "/docs/DOC-"
    ],
    "excludePatterns": [
      "/login",
      "/logout",
      "/profile",
      "/people",
      "/admin"
    ],
    "waitForSelector": ".jive-rendered-content",
    "delay": 1000
  },
  "extraction": {
    "useHeuristics": true,
    "selectors": {
      "title": "h1, .j-placeTitle, span.j-place-name",
      "body": ".jive-rendered-content, .j-description",
      "category": "h2",
      "videos": "iframe[src*='vimeo'], iframe[src*='youtube']",
      "images": "img[src*='cachefly'], img[src*='/servlet/']",
      "documents": "a[href*='/docs/DOC-'], a[href*='/servlet/JiveServlet/download'], a[href$='.pdf']"
    }
  },
  "download": {
    "enabled": true,
    "downloadDir": "./output/hotel-design-vendors-extra/downloads",
    "allowedTypes": ["pdf", "docx", "xlsx", "pptx", "jpg", "png", "gif"],
    "maxFileSize": 52428800,
    "generateInventory": true,
    "deduplicateByTitle": true,
    "deduplicateByHash": true
  },
  "output": {
    "formats": ["json", "csv"],
    "jsonFile": "./output/hotel-design-vendors-extra/crawl.json",
    "csvFile": "./output/hotel-design-vendors-extra/crawl.csv",
    "inventoryFile": "./output/hotel-design-vendors-extra/file_inventory.csv",
    "summaryFile": "./output/hotel-design-vendors-extra/crawl_summary.json"
  }
}
